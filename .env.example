# OpenAI API Key (required)
OPENAI_API_KEY=sk-your-key-here

# LLM Configuration (optional — defaults to DeepSeek)
LLM_BASE_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# Application Settings
TIMEOUT_SECONDS=30
SESSION_STORAGE_PATH=data/sessions.json
LOG_LEVEL=info

# Set to true to auto-approve write/exec tools in /ask (dev mode)
ALLOW_AUTO_APPROVE=false

# Optional: CoinGecko API key for crypto price tool
# COINGECKO_API_KEY=
